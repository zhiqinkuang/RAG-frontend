*.sql
*.sqlite
*.sqlite3
*.db
*.db-journal

# 虚拟机和镜像
*.vmdk
*.vdi
*.qcow2
*.img

# ============================================
# 涉密文件 (Sensitive files)
# ============================================

# 环境变量文件
.env
.env.*
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# 密钥和证书
*.key
*.pem
*.crt
*.cer
*.p12
*.pfx
*.jks
*.keystore

# SSH密钥
id_rsa
id_dsa
id_ecdsa
id_ed25519
*.pub
.ssh/

# GPG密钥
*.gpg
*.asc
secring.*

# 凭证文件
credentials.json
secrets.json
service-account.json
*.credentials
*.secrets

# API密钥和Token文件
*_key.txt
*_token.txt
api_keys.json

# 敏感配置
.idea/
.vscode/launch.json
*.code-workspace

# 安全相关
.npmrc
.yarnrc.yml
