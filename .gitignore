# ============================================
# 大文件 (Large files)
# ============================================

# 日志文件
logs/
*.log
log/

# 临时文件
tmp/
temp/
*.tmp
*.temp
*.swp
*.swo
*~

# 缓存文件
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo

# 大型二进制文件
*.zip
*.tar.gz
*.tar
*.rar
*.7z
*.iso
*.dmg

# 视频文件
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm

# 音频文件
*.mp3
*.wav
*.flac
*.aac
*.ogg
*.wma

# 大型图片文件
*.psd
*.ai
