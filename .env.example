# 火山引擎豆包 API Key
ARK_API_KEY=your-ark-api-key-here

# 为 true：须先 RAG 账号登录才能进主站。不设或 false：可用设置里 API Key / 服务端 ARK_API_KEY（如仅豆包对话），无需 RAG登录
# NEXT_PUBLIC_REQUIRE_RAG_LOGIN=true

# OpenAI API Key（备用）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 设为 true 时使用 Mock 流式数据演示，无需 API Key
# MOCK_CHAT=true

# chat persistence -- sign up on cloud.assistant-ui.com
# NEXT_PUBLIC_ASSISTANT_BASE_URL=

# RAG 后端（鉴权/知识库）：
# - NEXT_PUBLIC_RAG_API_URL：浏览器端使用的 API 地址
#   - 空字符串表示使用相对路径（通过 nginx 代理，生产部署推荐）
#   - 有值则直接使用该值（如 http://your-server:8080）
# - RAG_API_URL：Next.js 服务端代理使用（优先级高于请求体里的 baseURL）
# RAG 知识库对话时传给后端的 model（格式由你的 RAG 后端/上游厂商决定，如模型名或接入点 ID）
# RAG_CHAT_MODEL=
# NEXT_PUBLIC_RAG_API_URL=
# RAG_API_URL=http://127.0.0.1:8080